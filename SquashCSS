<DataTable
  columns={columns}
  serverSide
  service={caseTableService}
  buildServerQuery={buildServerQuery}
  reloadToken={reloadToken}
  pageSize={10}
  pageSizeOptions={[5, 10, 25, 50]}
  sortableColumns={["caseId", "creationDate"]}
  searchableColumns={["caseId"]}
  filterMode="manual"
  manualFilterDelayMs={650}
  paginationPlacement="top"
  toolbarExtra={
    <button
      type="button"
      className="cm__refresh-btn"
      onClick={() => setReloadToken((token) => token + 1)}
      title="Refresh list"
    >
      ↺ Refresh
    </button>
  }
  selection={{
    enabled: showComparisonCheckboxes,
    rowKey: "caseId",
    selectedRowIds: selectedCaseIds,
    onSelectedRowIdsChange: handleSelectedCaseIdsChange,
    isRowSelectable: (row) => row.status === "Completed",
    maxSelectable: maxComparisonCount,
  }}
/>
