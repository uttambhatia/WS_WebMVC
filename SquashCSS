const buildServerQuery = useCallback(({ page, pageSize, filters }) => ({
  start: page - 1,
  size: pageSize,
  ...(filters?.caseId ? { id: filters.caseId } : {}),
}), []);


const caseTableService = useCallback(async (params) => {
  const result = await listSnapshotsPaged(params);
  const summaries = Array.isArray(result?.content) ? result.content : [];

  const data = await Promise.all(
    summaries.map(async (summary) => ({
      caseId: summary.caseId,
      completedUpTo: summary.completedUpTo,
      status: await resolveStatus(summary),
      creationDate: deriveCreationDate(summary.caseId),
    }))
  );

  return {
    data,
    total: result?.totalElements ?? 0,
  };
}, [selectedCaseIds]);
